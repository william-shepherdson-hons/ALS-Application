{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Adapt-Math",
  "version": "0.1.0",
  "identifier": "com.Adapt-Math.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Adapt-Math",
        "width": 800,
        "height": 600,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/128x128.png"
    ]
  }
}
